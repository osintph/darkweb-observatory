                    <th style="width: 20%">Type</th>
                </tr>
            </thead>
            <tbody>
        """
        for item in all_btc:
            html += f"""
                <tr data-ioc="{item['ioc'].lower()}" data-source="{item['source'].lower()}">
                    <td class="ioc-btc">{item['ioc']}</td>
                    <td><span class="source-tag">{item['source']}</span></td>
                    <td>Bitcoin</td>
                </tr>
            """
        html += "</tbody></table>"
    
    # PGP Keys
    if all_pgp:
        html += f"""
        <h2>🔐 PGP Key Fingerprints ({len(all_pgp)})</h2>
        <table id="pgpTable">
            <thead>
                <tr>
                    <th style="width: 50%">PGP Fingerprint</th>
                    <th style="width: 30%">Source Target</th>
                    <th style="width: 20%">Type</th>
                </tr>
            </thead>
            <tbody>
        """
        for item in all_pgp:
            html += f"""
                <tr data-ioc="{item['ioc'].lower()}" data-source="{item['source'].lower()}">
                    <td class="ioc-pgp">{item['ioc']}</td>
                    <td><span class="source-tag">{item['source']}</span></td>
                    <td>PGP Key</td>
                </tr>
            """
        html += "</tbody></table>"
    
    # Linked Onions
    if all_onions:
        html += f"""
        <h2>🧅 Linked Onion Services ({len(all_onions)})</h2>
        <table id="onionTable">
            <thead>
                <tr>
                    <th style="width: 50%">Onion Domain</th>
                    <th style="width: 30%">Discovered On</th>
                    <th style="width: 20%">Type</th>
                </tr>
            </thead>
