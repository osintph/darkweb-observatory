        """
        for item in all_onions:
            html += f"""
                <tr data-ioc="{item['ioc'].lower()}" data-source="{item['source'].lower()}">
                    <td class="ioc-onion">{item['ioc']}</td>
                    <td><span class="source-tag">{item['source']}</span></td>
                    <td>Onion Link</td>
                </tr>
            """
        html += "</tbody></table>"
    
    html += """
        <p style="margin-top:50px; font-size: 0.8em; color: #555;">
            <i>Automated Threat Intelligence Sentinel | IOC Aggregation Module</i>
        </p>
        
        <script>
        function searchIOCs() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            const allRows = document.querySelectorAll('table tbody tr');
            
            allRows.forEach(row => {
                const ioc = row.dataset.ioc || '';
                const source = row.dataset.source || '';
                
                if (ioc.includes(searchTerm) || source.includes(searchTerm)) {
                    row.classList.remove('hidden');
                } else{
                    row.classList.add('hidden');
                }
            });
        }
        
        function exportCSV() {
            let csv = 'IOC,Type,Source Target\\n';
            const allRows = document.querySelectorAll('table tbody tr');
            
            allRows.forEach(row => {
                if (!row.classList.contains('hidden')) {
                    const cols = row.querySelectorAll('td');
                    if (cols.length >= 3) {
                        const ioc = cols[0].textContent.trim();
                        const source = cols[1].textContent.trim();
                        const type = cols[2].textContent.trim();
                        csv += `"${ioc}","${type}","${source}"\\n`;
                    }
                }
            });
            
            const blob = new Blob([csv], { type: 'text/csv' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'ioc_database.csv';
            a.click();
        }
        </script>
    </body>
    </html>
    """
    
    return html

# ============== MAIN SCANNING ==============

def check_site(target):
    """Main site checking"""
    url = target['url']
    
    try:
        start_time = time.time()
        resp = requests.get(url, proxies=PROXIES, headers=HEADERS, timeout=60, verify=False)
        latency = round(time.time() - start_time, 2)
        
        soup = BeautifulSoup(resp.text, 'html.parser')
        title = extract_page_title(resp.text)
        server = resp.headers.get('Server', 'Unknown')
        
        result = {
            'status': None,
            'status_detail': None,
            'color': None,
            'latency': f"{latency}s",
            'title': title,
            'server': server,
            'deep_data': None,
            'http_code': resp.status_code
        }
        
        if target.get('deep_scan', False):
            print(f"    [DEEP SCAN ENABLED]")
            result['deep_data'] = deep_scan_site(url, resp, soup)
        
        if 200 <= resp.status_code < 300:
            result['status'] = "UP"
            result['status_detail'] = f"HTTP {resp.status_code}"
            result['color'] = "green"
        elif resp.status_code == 403:
            result['status'] = "ISSUES"
            result['status_detail'] = "HTTP 403 Forbidden"
            result['color'] = "orange"
            result['title'] = "Access Denied (403)"
        elif resp.status_code == 401:
            result['status'] = "ISSUES"
            result['status_detail'] = "HTTP 401 Unauthorized"
            result['color'] = "orange"
            result['title'] = "Authentication Required (401)"
        elif resp.status_code == 404:
            result['status'] = "ISSUES"
            result['status_detail'] = "HTTP 404 Not Found"
            result['color'] = "orange"
            result['title'] = "Page Not Found (404)"
        elif resp.status_code >= 500:
            result['status'] = "ISSUES"
            result['status_detail'] = f"HTTP {resp.status_code} Server Error"
            result['color'] = "orange"
            result['title'] = f"Server Error ({resp.status_code})"
        else:
            result['status'] = "ISSUES"
            result['status_detail'] = f"HTTP {resp.status_code}"
            result['color'] = "orange"
            result['title'] = f"Status {resp.status_code}"
        
        return result
            
    except requests.exceptions.ConnectionError:
        return {
            'status': "DOWN",
            'status_detail': "Connection Failed",
            'color': "red",
            'latency': "-",
            'title': "Connection Failed",
            'server': "-",
            'deep_data': None,
            'http_code': None
        }
    except requests.exceptions.Timeout:
        return {
            'status': "DOWN",
            'status_detail': "Timeout (>60s)",
            'color': "red",
            'latency': ">60s",
            'title': "Timed Out",
            'server': "-",
            'deep_data': None,
            'http_code': None
        }
    except Exception as e:
        return {
            'status': "ERROR",
            'status_detail': str(e)[:40],
            'color': "red",
            'latency': "-",
            'title': str(e)[:30],
            'server': "-",
            'deep_data': None,
            'http_code': None
        }

def load_previous_scans():
    """Load previous deep scan results"""
    try:
        with open(DEEP_SCAN_DB, 'r') as f:
            return json.load(f)
    except:
        return {}

def save_deep_scan_results(all_deep_data):
    """Save deep scan results"""
    try:
        with open(DEEP_SCAN_DB, 'w') as f:
            json.dump(all_deep_data, f, indent=2)
    except Exception as e:
        print(f"[!] Failed to save deep scan DB: {e}")

def calculate_intelligence_summary(all_results, deep_scan_data):
    """Calculate aggregate intelligence metrics"""
    
    total_targets = len(all_results)
    up_targets = sum(1 for r in all_results if r['result']['status'] == 'UP')
    down_targets = sum(1 for r in all_results if r['result']['status'] == 'DOWN')
    issues_targets = sum(1 for r in all_results if 'ISSUES' in r['result']['status'])
    
    deep_scan_count = sum(1 for r in all_results if r['deep_scan_enabled'])
    
    # IOC counts
    total_emails = 0
    total_btc = 0
    total_pgp = 0
    total_linked_onions = 0
    
    for target_name, data in deep_scan_data.items():
        total_emails += len(data.get('emails', []))
        total_btc += len(data.get('bitcoin_addresses', []))
        total_pgp += len(data.get('pgp_keys', []))
        total_linked_onions += len(data.get('linked_onions', []))
    
    # Calculate average latency (exclude failures)
    latencies = []
    for r in all_results:
        lat = r['result']['latency']
        if lat != '-' and '>' not in lat:
            try:
                latencies.append(float(lat.replace('s', '')))
            except:
                pass
    
    avg_latency = round(sum(latencies) / len(latencies), 2) if latencies else 0
    
    # Category breakdown
    categories = {}
    for r in all_results:
        cat = r['category']
        categories[cat] = categories.get(cat, 0) + 1
    
    uptime_percentage = round((up_targets / total_targets) * 100, 1) if total_targets > 0 else 0
    
    # Count changes detected
    changes_detected = sum(1 for r in all_results if r.get('change_info', {}).get('changed', False))
    
    return {
        'total_targets': total_targets,
        'up_targets': up_targets,
        'down_targets': down_targets,
        'issues_targets': issues_targets,
        'uptime_percentage': uptime_percentage,
        'deep_scan_count': deep_scan_count,
        'total_iocs': total_emails + total_btc + total_pgp,
        'total_emails': total_emails,
        'total_btc': total_btc,
        'total_pgp': total_pgp,
        'total_linked_onions': total_linked_onions,
        'avg_latency': avg_latency,
        'categories': categories,
        'changes_detected': changes_detected
    }

def generate_report():
    """Generate HTML dashboard and JSON feed"""
    
    now = datetime.datetime.now().astimezone()
    timestamp = now.strftime("%Y-%m-%d %H:%M %Z")
    
    print(f"[*] Starting threat intelligence scan at {timestamp}")
    if ALERTS_ENABLED:
        print(f"[*] Telegram alerts ENABLED")
    
    all_results = []
    deep_scan_data = load_previous_scans()
    previous_status = load_previous_status()
    
    # SCAN ALL TARGETS
    for target in TARGETS:
        print(f"  > Scanning {target['name']} [{target.get('category', 'unknown')}]...")
        
        result = check_site(target)
        
        print(f"    Result: {result['status']} ({result['latency']})")
        
        # Get previous status
        prev_status = previous_status.get(target['name'], {}).get('status', 'UNKNOWN')
        
        # Update uptime history
        uptime_24h = update_uptime_history(target['name'], result['status'])
        print(f"    24h Uptime: {uptime_24h}%")
        
        # TELEGRAM ALERTS - Status changes
        if ALERTS_ENABLED:
            # Alert on DOWN
            if result['status'] == 'DOWN' and prev_status != 'DOWN':
                alert_target_down(target['name'], target['url'], result.get('status_detail', 'Unknown'))
            
            # Alert on recovery
            if result['status'] == 'UP' and prev_status == 'DOWN':
                alert_target_recovery(target['name'], target['url'])
            
            # Alert on uptime drop
            if uptime_24h < 80.0:
                alert_uptime_drop(target['name'], uptime_24h)
        
        # Change detection
        # Initialize change_info before potential deep scan update to avoid NameError
        change_info = {'changed': False, 'change_type': None, 'last_changed': timestamp}
        
        if result['deep_data']:
            deep_scan_data[target['name']] = result['deep_data']
            print(f"    [+] Deep scan complete - {len(result['deep_data'].get('emails', []))} emails, "
                  f"{len(result['deep_data'].get('bitcoin_addresses', []))} BTC addresses, "
                  f"{len(result['deep_data'].get('linked_onions', []))} linked onions")
            
            # Detect changes
            change_info = detect_changes(
                target['name'],
                result['deep_data'].get('page_hash'),
                result['deep_data'].get('technologies', [])
            )
            
            # TELEGRAM ALERTS - Changes
            if ALERTS_ENABLED and change_info.get('changed'):
                alert_content_change(target['name'], target['url'], change_info.get('change_type'))
            
            # TELEGRAM ALERTS - New IOCs
            if ALERTS_ENABLED:
                ioc_summary = {
                    'emails': result['deep_data'].get('emails', []),
                    'bitcoin': result['deep_data'].get('bitcoin_addresses', []),
                    'pgp': result['deep_data'].get('pgp_keys', [])
                }
                if any(ioc_summary.values()):
                    alert_new_iocs(target['name'], ioc_summary)
        
        all_results.append({
            'name': target['name'],
            'url': target['url'],
            'category': target.get('category', 'unknown'),
            'status': result['status'],
            'latency_seconds': float(result['latency'].replace('s', '').replace('-', '0').replace('>', '')),
            'server': result['server'],
            'timestamp': timestamp,
            'deep_scan_enabled': target.get('deep_scan', False),
            'uptime_24h': uptime_24h,
            'change_info': change_info,
            'result': result
        })
    
    # Save current status for next scan
    current_status = {item['name']: {'status': item['status']} for item in all_results}
    save_previous_status(current_status)
    
    # Calculate intelligence summary
    intel_summary = calculate_intelligence_summary(all_results, deep_scan_data)
    
    # TELEGRAM - Send scan summary
    if ALERTS_ENABLED:
        send_scan_summary(intel_summary)
    
    # Save deep scan database and generate individual pages
    if deep_scan_data:
        save_deep_scan_results(deep_scan_data)
        print(f"[+] Deep scan database updated with {len(deep_scan_data)} entries")
        
        # Generate individual deep scan pages
        for target_name, data in deep_scan_data.items():
            filename = sanitize_filename(target_name)
            individual_html = generate_individual_deep_scan_page(target_name, data, timestamp)
            try:
                with open(f"{DEEP_SCAN_DIR}/{filename}.html", 'w') as f:
                    f.write(individual_html)
                print(f"    [+] Generated individual page: {filename}.html")
            except Exception as e:
                print(f"    [!] Failed to write {filename}.html: {e}")
        
        # Generate overview HTML
        deep_scan_html = generate_deep_scan_html(deep_scan_data, timestamp)
        try:
            with open(DEEP_SCAN_HTML, 'w') as f:
                f.write(deep_scan_html)
            print(f"[+] Deep scan overview HTML generated")
        except Exception as e:
            print(f"[!] Failed to write deep scan HTML: {e}")
        
        # Generate IOC database
        ioc_html = generate_ioc_database(deep_scan_data, timestamp)
        try:
            with open(IOC_DATABASE, 'w') as f:
                f.write(ioc_html)
            print(f"[+] IOC database generated with {intel_summary['total_iocs']} IOCs")
        except Exception as e:
            print(f"[!] Failed to write IOC database: {e}")
    
    # Check if links should appear
    has_deep_scans = any(target.get('deep_scan', False) for target in TARGETS)
    deep_scan_link = ''
    ioc_link = ''
    alert_stats_link = ''
    trends_link = ''
    threat_feed_link = ''
    if has_deep_scans and os.path.exists(DEEP_SCAN_DB):
        deep_scan_link = ' | <a href="deep_scan_results.html" class="intel-link">Deep Scan Database</a>'
    if has_deep_scans and os.path.exists(IOC_DATABASE):
        ioc_link = ' | <a href="ioc_database.html" class="intel-link">IOC Database</a>'
    if os.path.exists("/var/www/html/alert_statistics.html"):
        alert_stats_link = ' | <a href="alert_statistics.html" class="intel-link">Alert Statistics</a>'
    if os.path.exists("/var/www/html/historical_trends.html"):
        trends_link = ' | <a href="historical_trends.html" class="intel-link">Historical Trends</a>'
    if os.path.exists("/var/www/html/threat_feeds.html"):
        threat_feed_link = ' | <a href="threat_feeds.html" class="intel-link">Threat Intel Feeds</a>'
    
    # Generate HTML with Intelligence Summary Dashboard
    html_content = f"""
    <!DOCTYPE html>
    <html>
    <head>
        <title>Dark Web Observatory - Threat Intelligence Platform</title>
        <meta charset="UTF-8">
        <meta http-equiv="refresh" content="300"> 
        <style>
            body {{ font-family: 'Courier New', monospace; background: #0d0d0d; color: #e0e0e0; padding: 20px; }}
            h1 {{ color: #00ff00; text-transform: uppercase; border-bottom: 2px solid #333; padding-bottom: 10px; }}
            
            .intel-summary {{
                background: #1a1a1a;
                border: 2px solid #00ff00;
                padding: 25px;
                margin: 20px 0;
                border-radius: 5px;
            }}
            .intel-summary h2 {{
                color: #00ff00;
                margin: 0 0 20px 0;
                font-size: 1.2em;
                text-transform: uppercase;
            }}
            .metrics-grid {{
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
                gap: 15px;
                margin-bottom: 20px;
            }}
            .metric-box {{
                background: #0a0a0a;
                padding: 15px;
                border-left: 3px solid #333;
                transition: all 0.3s;
                cursor: default;
            }}
            .metric-box.clickable {{
                cursor: pointer;
            }}
            .metric-box.clickable:hover {{
                border-left-color: #00ff00;
                background: #111;
            }}
            .metric-label {{
                color: #888;
                font-size: 0.85em;
                text-transform: uppercase;
                margin-bottom: 5px;
            }}
            .metric-value {{
                color: #00ff00;
                font-size: 1.8em;
                font-weight: bold;
            }}
            .metric-value.warning {{ color: #ffa500; }}
            .metric-value.danger {{ color: #ff3333; }}
            
            .category-filters {{
                margin-top: 20px;
                padding-top: 15px;
                border-top: 1px solid #333;
            }}
            .filter-label {{
                color: #888;
                font-size: 0.85em;
                text-transform: uppercase;
                margin-bottom: 10px;
            }}
            .category-breakdown {{
                display: flex;
                flex-wrap: wrap;
                gap: 10px;
            }}
            .category-tag {{
                background: #0a0a0a;
                padding: 8px 15px;
                border-radius: 3px;
                font-size: 0.9em;
                border: 1px solid #333;
                cursor: pointer;
                transition: all 0.3s;
            }}
            .category-tag:hover {{
                border-color: #00ff00;
                background: #111;
            }}
            .category-tag.active {{
                background: #003300;
                border-color: #00ff00;
                color: #00ff00;
            }}
            .category-tag .count {{
                color: #00ff00;
                font-weight: bold;
                margin-left: 5px;
            }}
            
            .category {{ color: #888; font-size: 0.8em; text-transform: uppercase; }}
            table {{ border-collapse: collapse; width: 100%; max-width: 2000px; margin-top: 20px; font-size: 0.9em; }}
            th, td {{ border: 1px solid #333; padding: 12px; text-align: left; vertical-align: middle; }}
            th {{ background-color: #1a1a1a; color: #fff; text-transform: uppercase; letter-spacing: 1px; }}
            tr:nth-child(even) {{ background-color: #111; }}
            tr.hidden {{ display: none; }}
            a {{ color: #888; text-decoration: none; }}
            a:hover {{ color: #fff; text-decoration: underline; }}
            .green {{ color: #00ff00; font-weight: bold; background-color: #001a00; text-align: center; }}
            .orange {{ color: #ffa500; font-weight: bold; background-color: #1a1000; text-align: center; }}
            .red {{ color: #ff3333; font-weight: bold; background-color: #1a0000; text-align: center; }}
            .small {{ font-size: 0.85em; color: #999; }}
            .title-text {{ font-style: italic; color: #aaa; }}
            .deep-scan-badge {{ background: #003300; color: #00ff00; padding: 2px 6px; border-radius: 3px; font-size: 0.75em; }}
            .change-badge {{ background: #1a1000; color: #ffa500; padding: 2px 6px; border-radius: 3px; font-size: 0.75em; margin-left: 5px; animation: pulse 2s infinite; }}
            @keyframes pulse {{
                0%, 100% {{ opacity: 1; }}
                50% {{ opacity: 0.5; }}
            }}
            .intel-link {{ color: #00aaff; text-decoration: underline; cursor: pointer; }}
            .view-report-btn {{ background: #003300; color: #00ff00; padding: 4px 10px; border: 1px solid #00ff00; text-decoration: none; font-size: 0.85em; display: inline-block; }}
            .view-report-btn:hover {{ background: #004400; color: #fff; }}
            .uptime-bar {{
                width: 100%;
                height: 18px;
                background: #1a0000;
                border-radius: 3px;
                overflow: hidden;
                position: relative;
            }}
            .uptime-fill {{
                height: 100%;
                background: linear-gradient(90deg, #ff3333 0%, #ffa500 50%, #00ff00 100%);
                transition: width 0.3s;
            }}
            .uptime-text {{
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                text-align: center;
                line-height: 18px;
                font-size: 0.8em;
                font-weight: bold;
                color: #fff;
                text-shadow: 1px 1px 2px #000;
            }}
        </style>
    </head>
    <body>
        <h1>Dark Web Observatory - Threat Intelligence Platform</h1>
        <p>Last Scan: {timestamp} | <a href="intelligence.json" class="intel-link">Download Intel Feed (JSON)</a>{deep_scan_link}{ioc_link}{alert_stats_link}{trends_link}{threat_feed_link}</p>
        
        <div class="intel-summary">
            <h2>📊 Intelligence Summary (Last Scan)</h2>
            <div class="metrics-grid">
                <div class="metric-box">
                    <div class="metric-label">Total Targets</div>
                    <div class="metric-value">{intel_summary['total_targets']}</div>
                </div>
                <div class="metric-box">
                    <div class="metric-label">Targets UP</div>
                    <div class="metric-value">{intel_summary['up_targets']}</div>
                </div>
                <div class="metric-box clickable" onclick="window.location.href='deep_scan_results.html'" title="Click to view deep scan database">
                    <div class="metric-label">Deep Scans Active</div>
                    <div class="metric-value">{intel_summary['deep_scan_count']}</div>
                </div>
                <div class="metric-box {'clickable' if intel_summary['total_iocs'] > 0 else ''}" {('onclick="window.location.href=\'ioc_database.html\'" title="Click to view IOC database"' if intel_summary['total_iocs'] > 0 else '')}>
                    <div class="metric-label">IOCs Discovered</div>
                    <div class="metric-value {'danger' if intel_summary['total_iocs'] > 0 else ''}">{intel_summary['total_iocs']}</div>
                </div>
                <div class="metric-box {'clickable' if intel_summary['total_emails'] > 0 else ''}" {('onclick="window.location.href=\'ioc_database.html\'" title="Click to view emails"' if intel_summary['total_emails'] > 0 else '')}>
                    <div class="metric-label">Email Addresses</div>
                    <div class="metric-value danger">{intel_summary['total_emails']}</div>
                </div>
                <div class="metric-box {'clickable' if intel_summary['total_btc'] > 0 else ''}" {('onclick="window.location.href=\'ioc_database.html\'" title="Click to view Bitcoin addresses"' if intel_summary['total_btc'] > 0 else '')}>
                    <div class="metric-label">Bitcoin Addresses</div>
                    <div class="metric-value danger">{intel_summary['total_btc']}</div>
                </div>
                <div class="metric-box {'clickable' if intel_summary['total_pgp'] > 0 else ''}" {('onclick="window.location.href=\'ioc_database.html\'" title="Click to view PGP keys"' if intel_summary['total_pgp'] > 0 else '')}>
                    <div class="metric-label">PGP Keys</div>
                    <div class="metric-value danger">{intel_summary['total_pgp']}</div>
                </div>
                <div class="metric-box {'clickable' if intel_summary['changes_detected'] > 0 else ''}" {('title="Changes detected on monitored targets"' if intel_summary['changes_detected'] > 0 else '')}>
                    <div class="metric-label">Changes Detected</div>
                    <div class="metric-value {'warning' if intel_summary['changes_detected'] > 0 else ''}">{intel_summary['changes_detected']}</div>
                </div>
                <div class="metric-box">
                    <div class="metric-label">Avg Response Time</div>
                    <div class="metric-value">{intel_summary['avg_latency']}s</div>
                </div>
            </div>
            
            <div class="category-filters">
                <div class="filter-label">Filter by Category:</div>
                <div class="category-breakdown">
                    <div class="category-tag active" onclick="filterCategory('all')" data-category="all">
                        ALL TARGETS <span class="count">{intel_summary['total_targets']}</span>
                    </div>
"""
    
    # Add category filters
    for cat, count in sorted(intel_summary['categories'].items()):
        html_content += f'''
                    <div class="category-tag" onclick="filterCategory('{cat}')" data-category="{cat}">
                        {cat.upper()} <span class="count">{count}</span>
                    </div>'''
    
    html_content += """
                </div>
            </div>
        </div>
        
        <table id="targetsTable">
            <thead>
                <tr>
                    <th style="width: 10%">Target Name</th>
                    <th style="width: 22%">Onion Address</th>
                    <th style="width: 6%">Status</th>
                    <th style="width: 9%">Uptime (24h)</th>
                    <th style="width: 5%">Latency</th>
                    <th style="width: 8%">Server</th>
                    <th style="width: 10%">Last Changed</th>
                    <th style="width: 18%">Page Title / Error</th>
                    <th style="width: 12%">Deep Scan</th>
                </tr>
            </thead>
            <tbody>
    """

    # Build table rows
    for item in all_results:
        target_name = item['name']
        target_url = item['url']
        target_category = item['category']
        result = item['result']
        deep_scan_enabled = item['deep_scan_enabled']
        uptime_24h = item['uptime_24h']
        change_info = item.get('change_info', {})
        
        deep_badge = ' <span class="deep-scan-badge">DEEP SCAN</span>' if deep_scan_enabled else ''
        
        # Change badge
        if change_info.get('changed'):
            change_type = change_info.get('change_type', 'unknown')
            change_badge = f' <span class="change-badge" title="Changed: {change_type}">{change_type.upper()}</span>'
        else:
            change_badge = ''
        
        # Uptime bar
        uptime_cell = f'''
            <div class="uptime-bar">
                <div class="uptime-fill" style="width: {uptime_24h}%;"></div>
                <div class="uptime-text">{uptime_24h}%</div>
            </div>
        '''
        
        # Status
        status_display = result['status']
        if result.get('status_detail'):
            status_detail = result['status_detail']
            status_display = f'<span title="{status_detail}">{result["status"]}</span>'
        
        # Last changed
        if change_info.get('changed'):
            now_obj = datetime.datetime.now()
            last_changed_time = now_obj.strftime('%m-%d %H:%M')
            last_changed_cell = f'<span style="color: #ffa500;">{last_changed_time}</span>'
        else:
            last_changed_cell = '<span style="color: #555;">-</span>'
        
        # Deep scan column
        if deep_scan_enabled:
            filename = sanitize_filename(target_name)
            deep_scan_cell = f'<a href="deep_scans/{filename}.html" class="view-report-btn">View Report →</a>'
        else:
            deep_scan_cell = '<span style="color: #555;">Not enabled</span>'
        
        html_content += f"""
            <tr data-category="{target_category}">
                <td><span class="category">[{target_category}]</span><br>{target_name}{deep_badge}{change_badge}</td>
                <td class="small"><a href="{target_url}">{target_url}</a></td>
                <td class="{result['color']}">{status_display}</td>
                <td>{uptime_cell}</td>
                <td style="text-align: center;">{result['latency']}</td>
                <td class="small">{result['server']}</td>
                <td style="text-align: center;">{last_changed_cell}</td>
                <td class="title-text">{result['title']}</td>
                <td style="text-align: center;">{deep_scan_cell}</td>
            </tr>
        """

    html_content += """
            </tbody>
        </table>

        <div class="news-widget" style="margin-top: 40px; padding: 20px; background: #1a1a1a; border-left: 4px solid #ffa500;">
            <h2 style="color: #ffa500; margin-top: 0;">📰 Latest Cybersecurity News</h2>
            <div id="news-feed-container">
                <p style="color: #888;">Loading news feed...</p>
            </div>
        </div>

        <script>
        fetch('news_feed.json')
            .then(response => response.json())
            .then(data => {
                const container = document.getElementById('news-feed-container');
                const articles = data.articles.slice(0, 5); // Show top 5
                
                if (!articles || articles.length === 0) {
                    container.innerHTML = '<p style="color: #888;">No news available.</p>';
                    return;
                }
                
                let html = '<div style="display: grid; gap: 15px; margin-top: 15px;">';
                
                articles.forEach(article => {
                    // Simple cleanup
                    const title = article.title;
                    const desc = article.description.substring(0, 150) + '...';
                    const link = article.link;
                    const source = article.source;
                    
                    html += `
                        <div style="background: #0d0d0d; padding: 15px; border: 1px solid #333;">
                            <div style="display: flex; justify-content: space-between;">
                                <a href="${link}" target="_blank" style="color: #00aaff; font-weight: bold; text-decoration: none;">${title}</a>
                                <span style="color: #666; font-size: 0.8em;">${source}</span>
                            </div>
                            <p style="color: #ccc; font-size: 0.9em; margin: 8px 0;">${desc}</p>
                        </div>
                    `;
                });
                
                html += '</div>';
                container.innerHTML = html;
            })
            .catch(err => {
                console.error('News feed error:', err);
                document.getElementById('news-feed-container').innerHTML = 
                    '<p style="color: #ff3333;">Could not load news feed (ensure news_feed.json exists).</p>';
            });
        </script>
        <p style="margin-top:50px; font-size: 0.8em; color: #555;">
            <i>Automated Threat Intelligence Sentinel | Ubuntu 25.04 | Powered by Tor Network</i>
        </p>
        
        <script>
        let currentCategory = 'all';
        
        function filterCategory(category) {
            currentCategory = category;
            
            document.querySelectorAll('.category-tag').forEach(tag => {
                if (tag.dataset.category === category) {
                    tag.classList.add('active');
                } else {
                    tag.classList.remove('active');
                }
            });
            
            const rows = document.querySelectorAll('#targetsTable tbody tr');
            rows.forEach(row => {
                if (category === 'all' || row.dataset.category === category) {
                    row.classList.remove('hidden');
                } else {
                    row.classList.add('hidden');
                }
            });
        }
        </script>
    </body>
    </html>
    """

    # Write HTML
    try:
        with open(OUTPUT_HTML, "w") as f:
            f.write(html_content)
        print(f"[+] Dashboard updated")
    except PermissionError:
        print("[!] Error: Cannot write to /var/www/html")
    
    # Write JSON feed
    try:
        intel_feed = {
            'scan_timestamp': timestamp,
            'total_targets': len(TARGETS),
            'intelligence_summary': intel_summary,
            'targets': []
        }
        
        for item in all_results:
            target_data = {k: v for k, v in item.items() if k != 'result'}
            if item['deep_scan_enabled']:
                filename = sanitize_filename(item['name'])
                target_data['deep_scan_report_url'] = f"deep_scans/{filename}.html"
                target_data['deep_scan_json_url'] = f"deep_scan_results.json"
            intel_feed['targets'].append(target_data)
        
        with open(OUTPUT_JSON, 'w') as f:
            json.dump(intel_feed, f, indent=2)
        print(f"[+] Intelligence feed generated")
    except Exception as e:
        print(f"[!] Failed to write intelligence feed: {e}")
    
    print(f"\n[✓] Scan complete! Dashboard: http://localhost/")


    # Generate alert statistics dashboard
    try:
        from generate_alert_stats import generate_alert_statistics
        generate_alert_statistics()
    except Exception as e:
        print(f"[!] Failed to generate alert statistics: {e}")
    
    # Generate historical trends dashboard
    try:
        from generate_historical_trends import generate_historical_trends
        generate_historical_trends()
    except Exception as e:
        print(f"[!] Failed to generate historical trends: {e}")
    
    # Generate news feed
    try:
        from news_feed_aggregator import aggregate_news_feed
        aggregate_news_feed()
    except Exception as e:
        print(f"[!] Failed to generate news feed: {e}")

if __name__ == "__main__":
    generate_report()
