# ============== OPTIMIZED FILE HELPERS ==============

def load_json_file(filepath):
    try:
        with open(filepath, 'r') as f:
            return json.load(f)
    except:
        return {}

def save_json_file(filepath, data):
    try:
        with open(filepath, 'w') as f:
            json.dump(data, f, indent=2)
    except Exception as e:
        print(f"[!] Failed to save {filepath}: {e}")

def load_previous_status(): return load_json_file(PREVIOUS_STATUS)
def save_previous_status(data): save_json_file(PREVIOUS_STATUS, data)
def load_uptime_history(): return load_json_file(UPTIME_HISTORY)
def save_uptime_history(data): save_json_file(UPTIME_HISTORY, data)
def load_change_history(): return load_json_file(CHANGE_HISTORY)
def save_change_history(data): save_json_file(CHANGE_HISTORY, data)
def load_previous_scans(): return load_json_file(DEEP_SCAN_DB)
def save_deep_scan_results(data): save_json_file(DEEP_SCAN_DB, data)

def update_uptime_history(target_name, status):
    history = load_uptime_history()
    if target_name not in history:
        history[target_name] = {'checks': [], 'total_up': 0, 'total_checks': 0}
    
    is_up = (status == 'UP')
    timestamp = datetime.datetime.now().isoformat()
    
    history[target_name]['checks'].append({'timestamp': timestamp, 'status': status, 'up': is_up})
    history[target_name]['checks'] = history[target_name]['checks'][-96:]  # Last 24h
    
    checks = history[target_name]['checks']
    if checks:
        up_count = sum(1 for c in checks if c['up'])
        uptime_percent = round((up_count / len(checks)) * 100, 1)
        history[target_name]['uptime_24h'] = uptime_percent
        history[target_name]['total_checks'] = len(checks)
    else:
        history[target_name]['uptime_24h'] = 0.0
    
    save_uptime_history(history)
    return history[target_name]['uptime_24h']

# ============== OPTIMIZED CONTENT EXTRACTION ==============

# Pre-compiled regex patterns (OPTIMIZATION: compiled once instead of every call)
EMAIL_PATTERN = re.compile(r'\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Z|a-z]{2,}\b')
BITCOIN_PATTERN = re.compile(r'\b[13][a-km-zA-HJ-NP-Z1-9]{25,34}\b|bc1[a-z0-9]{39,59}\b')
PGP_BLOCK_PATTERN = re.compile(r'-----BEGIN PGP PUBLIC KEY BLOCK-----(.*?)-----END PGP PUBLIC KEY BLOCK-----', re.DOTALL)
PGP_FINGERPRINT_PATTERN = re.compile(r'[A-F0-9]{8,40}')
ONION_PATTERN = re.compile(r'[a-z2-7]{16,56}\.onion')
TITLE_PATTERN = re.compile(r'<title>(.*?)</title>', re.IGNORECASE | re.DOTALL)

def extract_page_title(html_content):
    try:
        match = TITLE_PATTERN.search(html_content)
        if match: return match.group(1).strip()[:60]
    except: pass
    return "Unknown Title"

def extract_emails(content):
    return list(set(EMAIL_PATTERN.findall(content)))[:10]

def extract_bitcoin_addresses(content):
    return list(set(BITCOIN_PATTERN.findall(content)))[:5]

def extract_pgp_keys(content):
    blocks = PGP_BLOCK_PATTERN.findall(content)[:3]
    fingerprints = []
    for block in blocks:
        m = PGP_FINGERPRINT_PATTERN.search(block)
        if m: fingerprints.append(m.group(0))
    return fingerprints

def extract_onion_links(html_content, base_url):
    onions = list(set(ONION_PATTERN.findall(html_content)))
    base = urlparse(base_url).netloc
    return [o for o in onions if o != base][:10]

# ============== CHANGE DETECTION ==============

@lru_cache(maxsize=128)  # OPTIMIZATION: Cache normalized HTML
def normalize_html_content(content):
    """Normalize HTML to ignore dynamic noise (timestamps, nonces)"""
    try:
        soup = BeautifulSoup(content, 'html.parser')
        for element in soup(["script", "style", "meta", "noscript", "iframe"]):
            element.decompose()
        text = soup.get_text(separator=' ')
        return ' '.join(text.split())
    except:
        return content

def calculate_page_hash(content):
    normalized = normalize_html_content(content)
    return hashlib.sha256(normalized.encode()).hexdigest()

def detect_changes(target_name, current_hash, current_technologies):
    """Detect if target has changed"""
    history = load_change_history()
    timestamp = datetime.datetime.now().isoformat()
    
    if target_name not in history:
        history[target_name] = {
            'first_seen': timestamp,
            'last_hash': current_hash,
            'last_technologies': current_technologies,
            'last_changed': timestamp,
            'change_count': 0,
            'changes': []
        }
        save_change_history(history)
        return {'changed': False, 'change_type': None, 'last_changed': timestamp}
    
    target_history = history[target_name]
    previous_hash = target_history.get('last_hash')
    previous_tech = target_history.get('last_technologies', [])
    
    changes_detected = []
    
    if previous_hash and previous_hash != current_hash:
        changes_detected.append('content')
    
    tech_added = set(current_technologies) - set(previous_tech)
    tech_removed = set(previous_tech) - set(current_technologies)
    
    if tech_added or tech_removed:
        changes_detected.append('technology')
    
    if changes_detected:
        change_record = {
            'timestamp': timestamp,
            'change_types': changes_detected,
            'previous_hash': previous_hash[:16] + '...' if previous_hash else None,
            'new_hash': current_hash[:16] + '...',
            'tech_added': list(tech_added),
            'tech_removed': list(tech_removed)
        }
        
        target_history['changes'].append(change_record)
        target_history['changes'] = target_history['changes'][-20:]
        target_history['last_hash'] = current_hash
        target_history['last_technologies'] = current_technologies
        target_history['last_changed'] = timestamp
        target_history['change_count'] += 1
        
        save_change_history(history)
        
        print(f"    [!] CHANGE DETECTED: {', '.join(changes_detected)}")
        
        return {
            'changed': True,
            'change_type': ', '.join(changes_detected),
            'last_changed': timestamp,
            'details': change_record
        }
    else:
        target_history['last_hash'] = current_hash
        target_history['last_technologies'] = current_technologies
        save_change_history(history)
        return {'changed': False, 'change_type': None, 'last_changed': target_history.get('last_changed', timestamp)}

# ============== DEEP SCAN FUNCTIONS ==============

def extract_ssh_info(headers):
    return {'disclosed': True, 'fingerprint': headers.get('X-SSH-Fingerprint')} if headers.get('X-SSH-Fingerprint') else {'disclosed': False}

def analyze_server_headers(headers):
    analysis = {
        'server': headers.get('Server', 'Unknown'),
        'x_powered_by': headers.get('X-Powered-By', 'None'),
        'backend': headers.get('X-Backend-Server', 'None'),
        'real_ip_leaked': headers.get('X-Real-IP', 'No'),
        'php_version': None, 'apache_version': None, 'nginx_version': None
    }
    if 'Apache' in analysis['server']:
        m = re.search(r'Apache/([\d.]+)', analysis['server'])
        if m: analysis['apache_version'] = m.group(1)
    if 'nginx' in analysis['server']:
        m = re.search(r'nginx/([\d.]+)', analysis['server'])
        if m: analysis['nginx_version'] = m.group(1)
    if 'PHP' in analysis['x_powered_by']:
        m = re.search(r'PHP/([\d.]+)', analysis['x_powered_by'])
        if m: analysis['php_version'] = m.group(1)
    return analysis

def check_security_headers(headers):
    return {
        'csp': headers.get('Content-Security-Policy', 'Missing'),
        'x_frame_options': headers.get('X-Frame-Options', 'Missing'),
        'xss_protection': headers.get('X-XSS-Protection', 'Missing'),
        'hsts': headers.get('Strict-Transport-Security', 'Missing'),
        'referrer_policy': headers.get('Referrer-Policy', 'Missing')
    }

def extract_forms(soup):
    forms = []
    for form in soup.find_all('form')[:5]:
        data = {'action': form.get('action', 'N/A'), 'method': form.get('method', 'GET').upper(), 'inputs': []}
        for inp in form.find_all(['input', 'textarea']):
            data['inputs'].append({'name': inp.get('name', 'unnamed'), 'type': inp.get('type', 'text')})
        forms.append(data)
    return forms

def extract_javascript_files(soup, base_url):
    js = []
    for script in soup.find_all('script', src=True)[:10]:
        js.append(urljoin(base_url, script['src']))
    return js

def detect_technologies(html, headers):
    techs = []
    html_l = html.lower()
    if 'wp-content' in html_l or 'wordpress' in html_l: techs.append('WordPress')
    if 'drupal' in html_l: techs.append('Drupal')
    if 'joomla' in html_l: techs.append('Joomla')
    if 'django' in html_l: techs.append('Django')
    if 'laravel' in html_l: techs.append('Laravel')
    if 'react' in html_l: techs.append('React')
    if 'phpbb' in html_l: techs.append('phpBB')
    if 'PHP' in headers.get('X-Powered-By', ''): techs.append('PHP')
    if 'ASP.NET' in headers.get('X-Powered-By', ''): techs.append('ASP.NET')
    return techs

def analyze_cookies(headers):
    c = headers.get('Set-Cookie', '')
    return {'present': bool(c), 'secure_flag': 'Secure' in c, 'httponly_flag': 'HttpOnly' in c, 'samesite': 'SameSite' in c}

def deep_scan_site(url, resp, soup):
    return {
        'timestamp': datetime.datetime.now().isoformat(),
        'url': url,
        'page_hash': calculate_page_hash(resp.text),
        'emails': extract_emails(resp.text),
        'bitcoin_addresses': extract_bitcoin_addresses(resp.text),
        'pgp_keys': extract_pgp_keys(resp.text),
        'linked_onions': extract_onion_links(resp.text, url),
        'server_analysis': analyze_server_headers(resp.headers),
        'security_headers': check_security_headers(resp.headers),
        'ssh_info': {'disclosed': bool(resp.headers.get('X-SSH-Fingerprint'))},
        'cookies': {'present': bool(resp.headers.get('Set-Cookie'))},
        'technologies': detect_technologies(resp.text, resp.headers),
        'forms': extract_forms(soup),
        'javascript_files': extract_javascript_files(soup, url),
        'content_length': len(resp.content),
        'response_headers': dict(resp.headers),
        'ssl_info': {'enabled': url.startswith('https'), 'version': resp.raw.version if hasattr(resp.raw, 'version') else 'Unknown'}
    }

def sanitize_filename(name):
    return re.sub(r'[^a-zA-Z0-9_-]', '_', name).lower()

# ============== HTML GENERATION FUNCTIONS ==============

def generate_individual_deep_scan_page(target_name, data, timestamp):
    scan_time = data.get('timestamp', 'Unknown')
    url = data.get('url', 'Unknown')
    page_hash = data.get('page_hash', 'Unknown')[:16] + '...'
    
    html = f"""
    <!DOCTYPE html>
    <html>
    <head>
        <title>Deep Scan: {target_name}</title>
        <meta charset="UTF-8">
        <style>
            body {{ font-family: 'Courier New', monospace; background: #0d0d0d; color: #e0e0e0; padding: 20px; }}
            h1 {{ color: #00ff00; text-transform: uppercase; border-bottom: 2px solid #333; padding-bottom: 10px; }}
            h2 {{ color: #ffa500; border-bottom: 1px solid #444; padding-bottom: 8px; margin-top: 30px; }}
            h3 {{ color: #00aaff; margin-top: 20px; font-size: 1.1em; }}
            .back-link {{ color: #00aaff; text-decoration: none; }}
            .back-link:hover {{ text-decoration: underline; }}
            .stat-grid {{ display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin: 15px 0; }}
            .stat-box {{ background: #0a0a0a; padding: 12px; border: 1px solid #333; }}
            .stat-label {{ color: #888; font-size: 0.85em; text-transform: uppercase; }}
            .stat-value {{ color: #00ff00; font-size: 1.1em; margin-top: 5px; }}
            .warning {{ color: #ff3333; }}
            .success {{ color: #00ff00; }}
            .info {{ color: #00aaff; }}
            .code {{ background: #0a0a0a; padding: 10px; border-left: 3px solid #333; margin: 10px 0; overflow-x: auto; }}
            .list-item {{ background: #0a0a0a; padding: 8px; margin: 5px 0; border-left: 2px solid #444; }}
            table {{ border-collapse: collapse; width: 100%; margin: 15px 0; }}
            th, td {{ border: 1px solid #333; padding: 10px; text-align: left; }}
            th {{ background: #1a1a1a; color: #fff; }}
            tr:nth-child(even) {{ background: #111; }}
            .timestamp {{ color: #666; font-size: 0.9em; }}
        </style>
    </head>
    <body>
        <h1>Deep Scan Report: {target_name}</h1>
        <p><a href="../index.html" class="back-link">&larr; Back to Dashboard</a> | <a href="../deep_scan_results.html" class="back-link">All Deep Scans</a> | <a href="../ioc_database.html" class="back-link">IOC Database</a> | Last Updated: {timestamp}</p>
        
        <p class="timestamp">Scanned: {scan_time}</p>
        <div class="code">URL: {url}</div>
        <div class="code">Page Hash: {page_hash}</div>
        
        <h2>Intelligence Summary</h2>
        <div class="stat-grid">
            <div class="stat-box">
                <div class="stat-label">Email Addresses</div>
                <div class="stat-value {'warning' if data.get('emails') else ''}">{len(data.get('emails', []))}</div>
            </div>
            <div class="stat-box">
                <div class="stat-label">Bitcoin Addresses</div>
                <div class="stat-value {'warning' if data.get('bitcoin_addresses') else ''}">{len(data.get('bitcoin_addresses', []))}</div>
            </div>
            <div class="stat-box">
                <div class="stat-label">PGP Keys</div>
                <div class="stat-value {'warning' if data.get('pgp_keys') else ''}">{len(data.get('pgp_keys', []))}</div>
            </div>
            <div class="stat-box">
                <div class="stat-label">Linked Onions</div>
                <div class="stat-value {'info' if data.get('linked_onions') else ''}">{len(data.get('linked_onions', []))}</div>
            </div>
            <div class="stat-box">
                <div class="stat-label">Forms Detected</div>
                <div class="stat-value">{len(data.get('forms', []))}</div>
            </div>
            <div class="stat-box">
                <div class="stat-label">Content Size</div>
                <div class="stat-value">{data.get('content_length', 0):,} bytes</div>
            </div>
        </div>
    """
    
    if data.get('emails'):
        html += "<h2>Extracted Email Addresses (IOCs)</h2>"
        for email in data.get('emails', []):
            html += f'<div class="list-item warning">{email}</div>'
    
    if data.get('bitcoin_addresses'):
        html += "<h2>Bitcoin Addresses Detected (IOCs)</h2>"
        for btc in data.get('bitcoin_addresses', []):
            html += f'<div class="list-item warning">{btc}</div>'
    
    if data.get('pgp_keys'):
        html += "<h2>PGP Key Fingerprints (IOCs)</h2>"
        for pgp in data.get('pgp_keys', []):
            html += f'<div class="list-item warning">{pgp}</div>'
    
    if data.get('linked_onions'):
        html += "<h2>Linked Onion Services (Network Mapping)</h2>"
        for onion in data.get('linked_onions', []):
            html += f'<div class="list-item info">{onion}</div>'
    
    server_data = data.get('server_analysis', {})
    html += f"""
        <h2>Server Infrastructure</h2>
        <table>
            <tr><th>Property</th><th>Value</th><th>Assessment</th></tr>
            <tr><td>Server</td><td>{server_data.get('server', 'Unknown')}</td><td>{'<span class="success">Version hidden (good OPSEC)</span>' if server_data.get('server') == 'Apache' and not server_data.get('apache_version') else '<span class="warning">Version exposed</span>' if server_data.get('apache_version') or server_data.get('nginx_version') else '<span class="success">Version hidden</span>'}</td></tr>
            <tr><td>Backend</td><td>{server_data.get('backend', 'None')}</td><td>{'<span class="warning">Backend server disclosed</span>' if server_data.get('backend') != 'None' else '<span class="success">Not disclosed</span>'}</td></tr>
            <tr><td>Real IP Leaked</td><td>{server_data.get('real_ip_leaked', 'No')}</td><td>{'<span class="warning">Critical OPSEC failure!</span>' if server_data.get('real_ip_leaked') != 'No' else '<span class="success">Not leaked</span>'}</td></tr>
            <tr><td>PHP Version</td><td>{server_data.get('php_version') or 'Not disclosed'}</td><td>{'<span class="warning">Version exposed</span>' if server_data.get('php_version') else '<span class="success">Hidden</span>'}</td></tr>
        </table>
    """
    
    sec_headers = data.get('security_headers', {})
    missing_headers = sum(1 for v in sec_headers.values() if v == 'Missing')
    html += f"""
        <h2>Security Posture ({missing_headers}/5 headers missing)</h2>
        <table>
            <tr><th>Header</th><th>Status</th></tr>
            <tr><td>Content-Security-Policy</td><td><span class="{'warning' if sec_headers.get('csp') == 'Missing' else 'success'}">{sec_headers.get('csp', 'Missing')}</span></td></tr>
            <tr><td>X-Frame-Options</td><td><span class="{'warning' if sec_headers.get('x_frame_options') == 'Missing' else 'success'}">{sec_headers.get('x_frame_options', 'Missing')}</span></td></tr>
            <tr><td>X-XSS-Protection</td><td><span class="{'warning' if sec_headers.get('xss_protection') == 'Missing' else 'success'}">{sec_headers.get('xss_protection', 'Missing')}</span></td></tr>
            <tr><td>Strict-Transport-Security</td><td><span class="{'warning' if sec_headers.get('hsts') == 'Missing' else 'success'}">{sec_headers.get('hsts', 'Missing')}</span></td></tr>
            <tr><td>Referrer-Policy</td><td><span class="{'warning' if sec_headers.get('referrer_policy') == 'Missing' else 'success'}">{sec_headers.get('referrer_policy', 'Missing')}</span></td></tr>
        </table>
    """
    
    cookies = data.get('cookies', {})
    if cookies.get('present'):
        html += f"""
            <h2>Cookie Security Analysis</h2>
            <table>
                <tr><th>Property</th><th>Status</th><th>Assessment</th></tr>
                <tr><td>Secure Flag</td><td>{'<span class="success">Yes</span>' if cookies.get('secure_flag') else '<span class="warning">No</span>'}</td><td>{'Protected' if cookies.get('secure_flag') else 'Vulnerable to interception'}</td></tr>
                <tr><td>HttpOnly Flag</td><td>{'<span class="success">Yes</span>' if cookies.get('httponly_flag') else '<span class="warning">No</span>'}</td><td>{'XSS protected' if cookies.get('httponly_flag') else 'Vulnerable to XSS'}</td></tr>
                <tr><td>SameSite</td><td>{'<span class="success">Yes</span>' if cookies.get('samesite') else '<span class="warning">No</span>'}</td><td>{'CSRF protected' if cookies.get('samesite') else 'Vulnerable to CSRF'}</td></tr>
            </table>
        """
    
    if data.get('technologies'):
        html += "<h2>Technologies Detected</h2>"
        for tech in data.get('technologies', []):
            html += f'<div class="list-item">{tech}</div>'
    
    if data.get('forms'):
        html += f"<h2>Forms Discovered ({len(data.get('forms', []))} forms)</h2>"
        for idx, form in enumerate(data.get('forms', []), 1):
            html += f"""
                <div class="list-item">
                    <strong>Form {idx}: {form.get('method', 'GET')} → {form.get('action', 'N/A')}</strong><br>
                    Inputs: {', '.join([f"{inp.get('name')} ({inp.get('type')})" for inp in form.get('inputs', [])])}
                </div>
            """
    
    if data.get('javascript_files'):
        html += f"<h2>JavaScript Assets ({len(data.get('javascript_files', []))} files)</h2>"
        for js in data.get('javascript_files', []):
            js_name = js.split('/')[-1]
            html += f'<div class="list-item"><span class="info">{js_name}</span></div>'
    
    ssl_info = data.get('ssl_info', {})
    html += f"""
        <h2>SSL/TLS Configuration</h2>
        <table>
            <tr><th>Property</th><th>Value</th></tr>
            <tr><td>HTTPS Enabled</td><td>{'<span class="success">Yes</span>' if ssl_info.get('enabled') else '<span class="warning">No (HTTP only)</span>'}</td></tr>
            <tr><td>TLS Version</td><td>{ssl_info.get('version', 'Unknown')}</td></tr>
        </table>
    """
    
    html += """
        <p style="margin-top:50px; font-size: 0.8em; color: #555;">
            <i>Automated Threat Intelligence Sentinel | Deep Reconnaissance Module</i>
        </p>
    </body>
    </html>
    """
    
    return html

